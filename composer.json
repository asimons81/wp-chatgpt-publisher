{
  "name": "wp-chatgpt-publisher/wp-chatgpt-publisher",
  "description": "Development tooling for the Editorial Publisher for ChatGPT WordPress plugin.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.1"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
    "php-stubs/wordpress-stubs": "^6.9",
    "phpunit/phpunit": "^9.6",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "wp-coding-standards/wpcs": "^3.2",
    "yoast/phpunit-polyfills": "^3.1"
  },
  "scripts": {
    "phpcs": "phpcs --standard=phpcs.xml.dist",
    "phpcbf": "phpcbf --standard=phpcs.xml.dist",
    "phpstan": "phpstan analyse --configuration=phpstan.neon.dist",
    "test": "phpunit -c phpunit.xml.dist"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "8.1.0"
    },
    "sort-packages": true
  }
}
