NODE_ENV=development
PORT=8787
PUBLIC_BASE_URL=https://mcp.example.com
# Optional local host port for Docker Compose when 8787 is already in use.
MCP_HOST_PORT=8787
DATABASE_URL=postgresql://wpcp:wpcp@postgres:5432/wpcp
# Generate with: openssl rand -base64 32
WPCP_ENCRYPTION_KEY=
# Generate with: openssl rand -base64 32
WPCP_TOKEN_SIGNING_KEY=
ALLOWED_ORIGINS=https://chatgpt.com
ALLOW_PRIVATE_NETWORKS_IN_DEVELOPMENT=false
CONNECTOR_UPLOAD_DIRS=/mnt/data
TRUST_PROXY=1
METRICS_ENABLED=false
TELEMETRY_ENABLED=false
LOG_LEVEL=info
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
CONFIRMATION_TTL_SECONDS=300
WORDPRESS_REQUEST_TIMEOUT_MS=10000
WORDPRESS_MAX_RESPONSE_BYTES=2097152
